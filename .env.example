# Copy to .env and fill in. All settings use the TWIN_ prefix.
# Never commit .env.

# --- Storage ---
# Production: PostgreSQL. Local development: sqlite:///twin.db
TWIN_DATABASE_URL=postgresql+psycopg://twin:change-me@localhost:5432/twin

# --- Authentication (required in production) ---
# Auth is ON by default. On first boot with an empty key table, this literal
# key is registered as the admin key; rotate it via /api/admin/keys afterwards.
TWIN_AUTH_ENABLED=true
TWIN_BOOTSTRAP_ADMIN_KEY=
TWIN_RATE_LIMIT_PER_MINUTE=600

# --- Embeddings (semantic drift detection) ---
# sentence-transformers (default, requires requirements-ml.txt) or hashing
# (degraded lexical mode, no model download).
TWIN_EMBEDDINGS_BACKEND=sentence-transformers
TWIN_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- LLM judge (escalation tiers) ---
# OpenAI-compatible endpoint. Leave the key empty to fall back to the
# deterministic judge (logged as degraded).
TWIN_LLM_API_KEY=
TWIN_LLM_BASE_URL=
TWIN_LLM_MODEL=gpt-4o-mini
TWIN_LLM_MODEL_DEEP=gpt-4o
TWIN_LLM_TIMEOUT=20

# --- Judge backend (optional integration) ---
# "llm" (default), "llamafirewall" (Meta LlamaFirewall small tier; LLM stays
# as the deep tier when a key is set), or "stub" (deterministic only).
# Requires requirements-integrations.txt for llamafirewall.
TWIN_JUDGE_BACKEND=llm
# TWIN_LLAMAFIREWALL_SCANNERS=prompt_guard,alignment_check

# --- Inline rail backend (optional integration) ---
# "native" (default, deterministic zero-inference) or "nemo" (NeMo Guardrails
# advisory denials on top of the native rail). NeMo requires a Colang config.
TWIN_GUARD_BACKEND=native
# TWIN_NEMO_CONFIG_PATH=/etc/twin/nemo_rails

# --- Per-workflow threshold profiles (optional) ---
# JSON: override detection thresholds per Span.workflow label.
# TWIN_THRESHOLD_PROFILES={"finance":{"flag_threshold":0.5,"watch_threshold":0.3}}

# --- Escalation-rate anomaly monitor (guards the paid judge tier) ---
TWIN_ESCALATION_WINDOW_SECONDS=300
TWIN_ESCALATION_RATIO_THRESHOLD=0.5
TWIN_ESCALATION_MIN_SAMPLES=20
# TWIN_ESCALATION_RATE_THRESHOLD_PER_MIN=

# --- Compliance mapping (optional) ---
# Path to a JSON file mapping audit action -> [clause,...]; merges over the
# built-in EU AI Act / NIST AI RMF / ISO 42001 defaults.
# TWIN_COMPLIANCE_MAP_PATH=/etc/twin/compliance_map.json

# --- Detection policy ---
TWIN_FLAG_THRESHOLD=0.60
TWIN_WATCH_THRESHOLD=0.35
TWIN_HARD_FLAG_SEVERITY=0.85
TWIN_LOW_PRIVILEGE_SAMPLE_RATE=3
# Comma-separated or JSON list; extends/overrides the sensitive tool gate.
# TWIN_DANGEROUS_TOOLS=transfer_funds,wire_transfer,delete_records

# --- Ingestion limits ---
TWIN_MAX_BATCH_SIZE=500
TWIN_MAX_BODY_BYTES=8388608

# --- Retention (optional; used by scripts/retention.py and the admin API) ---
# TWIN_RETENTION_DAYS=90

# --- Ops ---
TWIN_LOG_LEVEL=INFO
TWIN_LOG_JSON=true
TWIN_METRICS_ENABLED=true
TWIN_HOST=0.0.0.0
TWIN_PORT=8000
