# Copy to .env and fill in. Loaded from the process environment; never commit .env.
# The whole demo runs WITHOUT any of these (offline, deterministic StubJudge).

# --- Twin persistence ---
# Durable file DB (default). Set to ":memory:" for an ephemeral twin.
TWIN_DB=twin.db

# --- Online LLM judge (hybrid: called ONLY at the escalation tier) ---
# Leave LLM_API_KEY unset to stay fully offline (StubJudge).
# OpenAI-COMPATIBLE — works with OpenAI, Groq, OpenRouter, or a self-hosted endpoint.
#
# OpenAI (paid API account required — the free ChatGPT plan does NOT include API access):
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
#   LLM_MODEL_DEEP=gpt-4o
#
# Groq (has a free tier; OpenAI-compatible):
#   LLM_API_KEY=gsk_...
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# OpenRouter (free models available; OpenAI-compatible):
#   LLM_API_KEY=sk-or-...
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_MODEL_DEEP=gpt-4o-mini
LLM_PROVIDER=openai-compatible
